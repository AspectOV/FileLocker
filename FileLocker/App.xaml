<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="FileLocker.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileLocker">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!--  Other merged dictionaries here  -->
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                Compatibility shim: some templates reference SystemAccentColorPrimaryBrush which
                may not be defined by the WinUI version in use. Provide a fallback mapping to
                the platform accent color so ThemeResource lookups succeed during XAML load.
            -->
            <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{ThemeResource SystemAccentColor}" />

            <!--  Other app resources here  -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
