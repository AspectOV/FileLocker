<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppAccentColor">#7898BB</Color>
            <Color x:Key="AppAccentSoftColor">#1E2F43</Color>
            <Color x:Key="AppBackgroundStartColor">#09111A</Color>
            <Color x:Key="AppBackgroundEndColor">#141D28</Color>
            <Color x:Key="AppHeaderSurfaceColor">#101925</Color>
            <Color x:Key="AppSurfaceColor">#111A26</Color>
            <Color x:Key="AppSurfaceAltColor">#0D151F</Color>
            <Color x:Key="AppSurfaceRaisedColor">#172232</Color>
            <Color x:Key="AppInputSurfaceColor">#0D1622</Color>
            <Color x:Key="AppBorderColor">#233142</Color>
            <Color x:Key="AppBorderStrongColor">#30445A</Color>
            <Color x:Key="AppTextPrimaryColor">#F5F7FA</Color>
            <Color x:Key="AppTextSecondaryColor">#A4AFBE</Color>
            <Color x:Key="AppTextTertiaryColor">#748295</Color>
            <Color x:Key="AppDropActiveColor">#1C2B41</Color>
            <Color x:Key="AppStatusSurfaceColor">#0E1722</Color>
            <Color x:Key="AppButtonGhostColor">#162130</Color>
            <Color x:Key="AppPrimaryActionColor">#7898BB</Color>
            <Color x:Key="AppPrimaryActionForegroundColor">#081018</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppAccentColor">#3E638A</Color>
            <Color x:Key="AppAccentSoftColor">#E3EBF4</Color>
            <Color x:Key="AppBackgroundStartColor">#F4F7FA</Color>
            <Color x:Key="AppBackgroundEndColor">#E8EDF3</Color>
            <Color x:Key="AppHeaderSurfaceColor">#F8FAFC</Color>
            <Color x:Key="AppSurfaceColor">#FFFFFF</Color>
            <Color x:Key="AppSurfaceAltColor">#F7F9FC</Color>
            <Color x:Key="AppSurfaceRaisedColor">#EEF3F8</Color>
            <Color x:Key="AppInputSurfaceColor">#F6F8FB</Color>
            <Color x:Key="AppBorderColor">#D4DCE6</Color>
            <Color x:Key="AppBorderStrongColor">#BCC9D7</Color>
            <Color x:Key="AppTextPrimaryColor">#16202B</Color>
            <Color x:Key="AppTextSecondaryColor">#5F6D7C</Color>
            <Color x:Key="AppTextTertiaryColor">#7B8794</Color>
            <Color x:Key="AppDropActiveColor">#DCE7F4</Color>
            <Color x:Key="AppStatusSurfaceColor">#F7F9FC</Color>
            <Color x:Key="AppButtonGhostColor">#F3F6FA</Color>
            <Color x:Key="AppPrimaryActionColor">#3E638A</Color>
            <Color x:Key="AppPrimaryActionForegroundColor">#FFFFFF</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <LinearGradientBrush x:Key="MainWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{ThemeResource AppBackgroundStartColor}" Offset="0" />
        <GradientStop Color="{ThemeResource AppBackgroundEndColor}" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="HeaderSurfaceBrush" Color="{ThemeResource AppHeaderSurfaceColor}" />
    <SolidColorBrush x:Key="WorkspaceSurfaceBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="InspectorSurfaceBrush" Color="{ThemeResource AppSurfaceAltColor}" />
    <SolidColorBrush x:Key="RaisedSurfaceBrush" Color="{ThemeResource AppSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="InputSurfaceBrush" Color="{ThemeResource AppInputSurfaceColor}" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="{ThemeResource AppBorderColor}" />
    <SolidColorBrush x:Key="AppBorderStrongBrush" Color="{ThemeResource AppBorderStrongColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{ThemeResource AppTextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{ThemeResource AppTextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{ThemeResource AppTextTertiaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{ThemeResource AppAccentSoftColor}" />
    <SolidColorBrush x:Key="DropPanelBrush" Color="{ThemeResource AppSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="DropPanelBorderBrush" Color="{ThemeResource AppBorderStrongColor}" />
    <SolidColorBrush x:Key="DropPanelActiveBrush" Color="{ThemeResource AppDropActiveColor}" />
    <SolidColorBrush x:Key="StatusSurfaceBrush" Color="{ThemeResource AppStatusSurfaceColor}" />
    <SolidColorBrush x:Key="ButtonGhostBrush" Color="{ThemeResource AppButtonGhostColor}" />
    <SolidColorBrush x:Key="PrimaryActionBrush" Color="{ThemeResource AppPrimaryActionColor}" />
    <SolidColorBrush x:Key="PrimaryActionForegroundBrush" Color="{ThemeResource AppPrimaryActionForegroundColor}" />

    <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="120" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BadgeBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="{ThemeResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource WorkspaceSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
    </Style>

    <Style x:Key="RaisedPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource RaisedSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
    </Style>
</ResourceDictionary>
