<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FileLocker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FileLocker"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="FileLocker"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource MainWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="22,16,22,14"
            Background="{ThemeResource HeaderSurfaceBrush}"
            BorderBrush="{ThemeResource AppBorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="14">
                    <Border
                        Width="42"
                        Height="42"
                        Background="{ThemeResource AccentSoftBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="{ThemeResource AccentBrush}"
                            Glyph="&#xE72E;" />
                    </Border>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        Text="FileLocker" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Button
                        x:Name="AboutButton"
                        AccessKey="A"
                        AutomationProperties.Name="About FileLocker"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Background="{ThemeResource ButtonGhostBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        Click="About_Click"
                        CornerRadius="12"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        ToolTipService.ToolTip="About FileLocker">
                        <FlyoutBase.AttachedFlyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuFlyoutItem
                                    x:Name="AboutTitleMenuItem"
                                    Icon="Help"
                                    IsEnabled="False"
                                    Text="FileLocker" />
                                <MenuFlyoutItem
                                    x:Name="AboutVersionMenuItem"
                                    IsEnabled="False"
                                    Text="Version" />
                                <MenuFlyoutItem
                                    x:Name="AboutProfilesMenuItem"
                                    IsEnabled="False"
                                    Text="Profiles available" />
                                <MenuFlyoutItem
                                    x:Name="AboutUpdateStatusMenuItem"
                                    IsEnabled="False"
                                    Text="Updates: automatic checks enabled" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem
                                    Text="Check for Updates"
                                    Click="CheckForUpdatesMenuItem_Click" />
                                <MenuFlyoutItem
                                    Text="Open GitHub"
                                    Click="OpenGitHubMenuItem_Click" />
                                <MenuFlyoutItem
                                    Text="Open Reports Folder"
                                    Click="OpenReportsFolderMenuItem_Click" />
                                <MenuFlyoutItem
                                    Text="Open App Data Folder"
                                    Click="OpenAppDataFolderMenuItem_Click" />
                            </MenuFlyout>
                        </FlyoutBase.AttachedFlyout>
                        <FontIcon
                            FontSize="14"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            Glyph="&#xE946;" />
                    </Button>
                    <Button
                        x:Name="ThemeToggleButton"
                        AccessKey="T"
                        AutomationProperties.Name="Toggle theme"
                        MinWidth="84"
                        Height="40"
                        Padding="12,0"
                        Background="{ThemeResource ButtonGhostBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        Click="ThemeToggleButton_Click"
                        CornerRadius="12"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        ToolTipService.ToolTip="Switch color mode">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontSize="14"
                                Foreground="{ThemeResource TextSecondaryBrush}"
                                Glyph="&#xE706;" />
                            <TextBlock
                                x:Name="ThemeToggleLabel"
                                Foreground="{ThemeResource TextPrimaryBrush}"
                                Text="Dark" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            Padding="28,24,28,32"
            VerticalScrollBarVisibility="Auto">
            <Grid
                MaxWidth="1360"
                RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="DropPanel"
                    Grid.Row="0"
                    MinHeight="180"
                    Padding="22"
                    AllowDrop="True"
                    Background="{ThemeResource DropPanelBrush}"
                    BorderBrush="{ThemeResource DropPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="26"
                    DragOver="DropPanel_DragOver"
                    Drop="DropPanel_Drop"
                    PointerPressed="DropPanel_PointerPressed">
                    <Grid ColumnSpacing="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Spacing="14">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="36"
                                Foreground="{ThemeResource AccentBrush}"
                                Glyph="&#xE8B7;" />
                            <TextBlock
                                x:Name="DropLabel"
                                HorizontalAlignment="Center"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextPrimaryBrush}"
                                Text="Drop files here or click to browse" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="20"
                            Background="{ThemeResource WorkspaceSurfaceBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="34"
                                        Height="34"
                                        Background="{ThemeResource AccentSoftBrush}"
                                        CornerRadius="10">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="{ThemeResource AccentBrush}"
                                            Glyph="&#xE72E;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Foreground="{ThemeResource TextPrimaryBrush}"
                                            Text="Encrypt selected items" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Use AES defaults or switch algorithms when needed." />
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="34"
                                        Height="34"
                                        Background="{ThemeResource AccentSoftBrush}"
                                        CornerRadius="10">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="{ThemeResource AccentBrush}"
                                            Glyph="&#xE785;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Foreground="{ThemeResource TextPrimaryBrush}"
                                            Text="Decrypt locked payloads" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Restore items with the same password and settings profile." />
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="34"
                                        Height="34"
                                        Background="{ThemeResource AccentSoftBrush}"
                                        CornerRadius="10">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="{ThemeResource AccentBrush}"
                                            Glyph="&#xE943;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Foreground="{ThemeResource TextPrimaryBrush}"
                                            Text="Generate hashes and Base64 output" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Quick integrity and encoding tools stay in the same workspace." />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.55*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="1.05*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Padding="28"
                            Spacing="20">

                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="Queue" />
                                <TextBlock
                                    x:Name="QueueSummaryText"
                                    Style="{StaticResource BodyTextStyle}"
                                    Text="No items queued" />
                            </StackPanel>
                            <Button
                                x:Name="ClearListButton"
                                AccessKey="L"
                                AutomationProperties.Name="Clear queued items"
                                Grid.Column="1"
                                MinWidth="92"
                                Height="38"
                                Padding="14,0"
                                VerticalAlignment="Top"
                                Background="{ThemeResource ButtonGhostBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}"
                                BorderThickness="1"
                                Click="ClearListButton_Click"
                                Content="Clear All"
                                CornerRadius="12"
                                Foreground="{ThemeResource TextPrimaryBrush}" />
                        </Grid>

                        <Border
                            MinHeight="320"
                            Padding="16"
                            Background="{ThemeResource InputSurfaceBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                            <StackPanel Spacing="14">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="Selected items" />
                                <ScrollViewer
                                    MaxHeight="360"
                                    VerticalScrollBarVisibility="Auto">
                                    <ListView
                                        x:Name="FileListBox"
                                        AutomationProperties.Name="Queued items"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="{ThemeResource RaisedSurfaceBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="16">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border
                                                            Width="34"
                                                            Height="34"
                                                            Background="{ThemeResource AccentSoftBrush}"
                                                            CornerRadius="10">
                                                            <FontIcon
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="14"
                                                                Foreground="{ThemeResource AccentBrush}"
                                                                Glyph="&#xE8A5;" />
                                                        </Border>
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Foreground="{ThemeResource TextPrimaryBrush}"
                                                            Text="{Binding}"
                                                            TextTrimming="CharacterEllipsis"
                                                            TextWrapping="WrapWholeWords" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </ScrollViewer>
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="Queue entries stay visible while you adjust passwords, algorithms, and metadata overrides." />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button
                                x:Name="EncryptButton"
                                AccessKey="E"
                                AutomationProperties.Name="Encrypt queued items"
                                Grid.Column="0"
                                Height="52"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource PrimaryActionBrush}"
                                BorderThickness="0"
                                Click="EncryptButton_Click"
                                CornerRadius="14"
                                Foreground="{ThemeResource PrimaryActionForegroundBrush}"
                                ToolTipService.ToolTip="Encrypt selected files">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon FontSize="18" Glyph="&#xE72E;" />
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="Encrypt" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="DecryptButton"
                                AccessKey="D"
                                AutomationProperties.Name="Decrypt queued items"
                                Grid.Column="1"
                                Height="52"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource ButtonGhostBrush}"
                                BorderBrush="{ThemeResource AppBorderStrongBrush}"
                                BorderThickness="1"
                                Click="DecryptButton_Click"
                                CornerRadius="14"
                                Foreground="{ThemeResource TextPrimaryBrush}"
                                ToolTipService.ToolTip="Decrypt selected files">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon FontSize="18" Glyph="&#xE785;" />
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="Decrypt" />
                                    </StackPanel>
                                </Button>

                            <Button
                                x:Name="CancelRunButton"
                                AccessKey="C"
                                AutomationProperties.Name="Cancel current run"
                                Grid.Column="2"
                                Width="110"
                                Height="52"
                                Background="{ThemeResource ButtonGhostBrush}"
                                BorderBrush="{ThemeResource AppBorderStrongBrush}"
                                BorderThickness="1"
                                Click="CancelRunButton_Click"
                                CornerRadius="14"
                                Foreground="{ThemeResource TextPrimaryBrush}"
                                IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon FontSize="16" Glyph="&#xE711;" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Cancel" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border
                            x:Name="HashHelperPanel"
                            Padding="20"
                            Background="{ThemeResource RaisedSurfaceBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Visibility="Collapsed">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="Hash and encode" />
                                    <TextBlock
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="Use the helper panel for SHA checks or Base64 output without leaving the queue view." />
                                </StackPanel>
                                <TextBox
                                    x:Name="HashInputBox"
                                    MinHeight="94"
                                    AcceptsReturn="True"
                                    Background="{ThemeResource InputSurfaceBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    FontSize="13"
                                    PlaceholderText="Enter text to hash or encode..." />
                                <Button
                                    x:Name="HashRunButton"
                                    Height="44"
                                    Padding="18,0"
                                    HorizontalAlignment="Left"
                                    Background="{ThemeResource PrimaryActionBrush}"
                                    BorderThickness="0"
                                    Click="HashRunButton_Click"
                                    Content="Generate Output"
                                    CornerRadius="14"
                                    Foreground="{ThemeResource PrimaryActionForegroundBrush}" />
                                <TextBox
                                    x:Name="HashOutputBox"
                                    MinHeight="94"
                                    AcceptsReturn="True"
                                    Background="{ThemeResource InputSurfaceBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    IsReadOnly="True"
                                    PlaceholderText="Output will appear here..." />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                        <Border
                            Grid.Column="1"
                            Background="{ThemeResource AppBorderBrush}" />

                        <Border
                            Grid.Column="2"
                            Background="{ThemeResource InspectorSurfaceBrush}"
                            CornerRadius="0,22,22,0">
                            <StackPanel
                                Padding="28"
                                Spacing="24">
                                <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Style="{StaticResource SectionTitleTextStyle}"
                                            Text="Inspector" />
                                        <ToggleSwitch
                                            x:Name="AdvancedModeToggle"
                                            Grid.Column="1"
                                            AutomationProperties.Name="Show advanced options"
                                            Header="Advanced"
                                            IsOn="False"
                                            Toggled="AdvancedModeToggle_Toggled" />
                                    </Grid>
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Password and profile first. Turn on advanced for everything else." />
                                </StackPanel>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        x:Name="SetupViewButton"
                                        Grid.Column="0"
                                        Height="38"
                                        Background="{ThemeResource AccentSoftBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        Click="SetupViewButton_Click"
                                        Content="Setup"
                                        CornerRadius="12"
                                        Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <Button
                                        x:Name="ChecksViewButton"
                                        Grid.Column="1"
                                        Height="38"
                                        Background="{ThemeResource ButtonGhostBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        Click="ChecksViewButton_Click"
                                        Content="Checks"
                                        CornerRadius="12"
                                        Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <Button
                                        x:Name="JobsViewButton"
                                        Grid.Column="2"
                                        Height="38"
                                        Background="{ThemeResource ButtonGhostBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        Click="JobsViewButton_Click"
                                        Content="Jobs"
                                        CornerRadius="12"
                                        Foreground="{ThemeResource TextPrimaryBrush}" />
                                </Grid>

                                <StackPanel
                                    x:Name="InspectorSetupPanel"
                                    Spacing="24">

                                <Border
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,24">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextPrimaryBrush}"
                                                Text="Password" />
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="Used locally to derive keys for encryption and decryption." />
                                        </StackPanel>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox
                                                x:Name="PasswordBox"
                                                AutomationProperties.Name="Password"
                                                Grid.Column="0"
                                                Height="46"
                                                Background="{ThemeResource InputSurfaceBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                FontSize="14"
                                                PasswordChanged="PasswordBox_PasswordChanged"
                                                PasswordRevealMode="Peek"
                                                PlaceholderText="Enter password (min 8 characters)" />
                                            <ToggleButton
                                                x:Name="ShowPasswordCheckBox"
                                                Grid.Column="1"
                                                Width="46"
                                                Height="46"
                                                Padding="0"
                                                Background="{ThemeResource ButtonGhostBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Checked="ShowPasswordCheckBox_Checked"
                                                CornerRadius="14"
                                                Foreground="{ThemeResource TextPrimaryBrush}"
                                                Unchecked="ShowPasswordCheckBox_Unchecked">
                                                <FontIcon FontSize="16" Glyph="&#xE7B3;" />
                                            </ToggleButton>
                                        </Grid>
                                        <StackPanel Spacing="8">
                                            <ProgressBar
                                                x:Name="PasswordStrengthBar"
                                                Height="6"
                                                Background="{ThemeResource AppBorderBrush}"
                                                CornerRadius="3"
                                                Maximum="100" />
                                            <TextBlock
                                                x:Name="PasswordStrengthText"
                                                Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                        <StackPanel
                                            x:Name="KeyfilePanel"
                                            Spacing="8"
                                            Visibility="Collapsed">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox
                                                    x:Name="KeyfilePathBox"
                                                    AutomationProperties.Name="Keyfile path"
                                                    Grid.Column="0"
                                                    Height="42"
                                                    Background="{ThemeResource InputSurfaceBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    FontSize="13"
                                                    PlaceholderText="Optional keyfile path"
                                                    TextChanged="KeyfilePathBox_TextChanged" />
                                                <Button
                                                    x:Name="BrowseKeyfileButton"
                                                    AccessKey="K"
                                                    AutomationProperties.Name="Browse for keyfile"
                                                    Grid.Column="1"
                                                    Height="42"
                                                    Padding="12,0"
                                                    Background="{ThemeResource ButtonGhostBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    Click="BrowseKeyfileButton_Click"
                                                    Content="Keyfile"
                                                    CornerRadius="14"
                                                    Foreground="{ThemeResource TextPrimaryBrush}" />
                                            </Grid>
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="Optional second factor for key derivation." />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,24">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextPrimaryBrush}"
                                                Text="Security profile" />
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="Pick a saved profile or tune the current encryption settings." />
                                        </StackPanel>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox
                                                x:Name="ProfileCombo"
                                                AutomationProperties.Name="Saved profile"
                                                Grid.Column="0"
                                                Background="{ThemeResource InputSurfaceBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                FontSize="13"
                                                Header="Profile"
                                                SelectionChanged="ProfileCombo_SelectionChanged" />
                                            <Button
                                                x:Name="SaveProfileButton"
                                                AccessKey="S"
                                                AutomationProperties.Name="Save current profile"
                                                Grid.Column="1"
                                                Height="42"
                                                Padding="12,0"
                                                Margin="0,24,0,0"
                                                Background="{ThemeResource ButtonGhostBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Click="SaveProfileButton_Click"
                                                Content="Save As"
                                                CornerRadius="14"
                                                Foreground="{ThemeResource TextPrimaryBrush}" />
                                        </Grid>
                                        <TextBlock
                                            x:Name="ProfileDescriptionText"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Balanced default for most files." />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Save current settings as a reusable custom profile." />
                                        <StackPanel
                                            x:Name="SecurityAdvancedPanel"
                                            Spacing="14"
                                            Visibility="Collapsed">
                                            <ComboBox
                                                x:Name="OperationModeCombo"
                                                AutomationProperties.Name="Operation mode"
                                                Background="{ThemeResource InputSurfaceBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                FontSize="14"
                                                Header="Mode"
                                                PlaceholderText="Select mode"
                                                SelectionChanged="OperationModeCombo_SelectionChanged">
                                                <ComboBoxItem Content="Encrypt / Decrypt" IsSelected="True" />
                                                <ComboBoxItem Content="Hash / Encode" />
                                            </ComboBox>
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox
                                                    x:Name="AlgorithmCombo"
                                                    AutomationProperties.Name="Algorithm"
                                                    Grid.Column="0"
                                                    Background="{ThemeResource InputSurfaceBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    FontSize="14"
                                                    Header="Algorithm"
                                                    PlaceholderText="Select algorithm"
                                                    SelectionChanged="AlgorithmCombo_SelectionChanged" />
                                                <ComboBox
                                                    x:Name="KeySizeCombo"
                                                    AutomationProperties.Name="Key size"
                                                    Grid.Column="1"
                                                    Background="{ThemeResource InputSurfaceBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    FontSize="14"
                                                    Header="Key Size"
                                                    PlaceholderText="Bits"
                                                    SelectionChanged="KeySizeCombo_SelectionChanged" />
                                            </Grid>
                                            <Button
                                                x:Name="RecommendedModeButton"
                                                AutomationProperties.Name="Apply recommended settings"
                                                Height="42"
                                                Padding="14,0"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource ButtonGhostBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Click="RecommendedModeButton_Click"
                                                Content="Use Recommended Settings"
                                                CornerRadius="14"
                                                Foreground="{ThemeResource TextPrimaryBrush}" />
                                            <Border
                                                Padding="14"
                                                Background="{ThemeResource AccentSoftBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                                <TextBlock
                                                    x:Name="AlgorithmHintText"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextPrimaryBrush}"
                                                    Text="Recommended: AES-GCM 256-bit"
                                                    TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border
                                    x:Name="OutputSafetySection"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,24"
                                    Visibility="Collapsed">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextPrimaryBrush}"
                                                Text="Output safety" />
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="Non-destructive by default, with verification and optional backups." />
                                        </StackPanel>
                                        <Border
                                            Padding="12"
                                            Background="{ThemeResource InputSurfaceBrush}"
                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                            <ToggleSwitch
                                                x:Name="RemoveOriginalsToggle"
                                                AutomationProperties.Name="Remove originals after success"
                                                FontSize="14"
                                                Header="Remove originals after a successful run"
                                                IsOn="False"
                                                Toggled="SafetyOption_Toggled" />
                                        </Border>
                                        <Border
                                            Padding="12"
                                            Background="{ThemeResource InputSurfaceBrush}"
                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                            <ToggleSwitch
                                                x:Name="SecureDeleteOriginalsToggle"
                                                AutomationProperties.Name="Secure delete originals"
                                                FontSize="14"
                                                Header="Use secure delete when originals are removed"
                                                IsOn="False"
                                                Toggled="SafetyOption_Toggled" />
                                        </Border>
                                        <Border
                                            Padding="12"
                                            Background="{ThemeResource InputSurfaceBrush}"
                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                            <ToggleSwitch
                                                x:Name="VerifyAfterWriteToggle"
                                                AutomationProperties.Name="Verify output after writing"
                                                FontSize="14"
                                                Header="Verify the written output before finishing"
                                                IsOn="True"
                                                Toggled="SafetyOption_Toggled" />
                                        </Border>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                x:Name="BackupFolderBox"
                                                AutomationProperties.Name="Backup folder"
                                                Grid.Column="0"
                                                Height="42"
                                                Background="{ThemeResource InputSurfaceBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                FontSize="13"
                                                PlaceholderText="Optional backup folder"
                                                TextChanged="BackupFolderBox_TextChanged" />
                                            <Button
                                                x:Name="BrowseBackupFolderButton"
                                                AutomationProperties.Name="Browse backup folder"
                                                Grid.Column="1"
                                                Height="42"
                                                Padding="12,0"
                                                Background="{ThemeResource ButtonGhostBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Click="BrowseBackupFolderButton_Click"
                                                Content="Backup"
                                                CornerRadius="14"
                                                Foreground="{ThemeResource TextPrimaryBrush}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <StackPanel
                                    x:Name="AdvancedHandlingPanel"
                                    Spacing="16"
                                    Visibility="Collapsed">
                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextPrimaryBrush}"
                                            Text="Advanced handling" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Control compression, filename behavior, and metadata overrides for the next run." />
                                    </StackPanel>
                                    <Border
                                        Padding="12"
                                        Background="{ThemeResource InputSurfaceBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                        <ToggleSwitch
                                            x:Name="CompressModeToggle"
                                            AutomationProperties.Name="Compress files before encryption"
                                            FontSize="14"
                                            Header="Compress files before encryption"
                                            IsOn="True"
                                            Toggled="CompressModeToggle_Toggled" />
                                    </Border>
                                    <Border
                                        Padding="12"
                                        Background="{ThemeResource InputSurfaceBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                        <ToggleSwitch
                                            x:Name="ScrambleNamesToggle"
                                            AutomationProperties.Name="Scramble file names"
                                            FontSize="14"
                                            Header="Scramble file names"
                                            IsOn="False"
                                            Toggled="ScrambleNamesToggle_Toggled" />
                                    </Border>
                                    <Border
                                        Padding="12"
                                        Background="{ThemeResource InputSurfaceBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                        <ToggleSwitch
                                            x:Name="SteganographyToggle"
                                            AutomationProperties.Name="Enable steganography"
                                            FontSize="14"
                                            Header="Enable steganography"
                                            IsOn="False"
                                            Toggled="SteganographyToggle_Toggled" />
                                    </Border>
                                    <Expander
                                        x:Name="MetadataExpander"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Header="File Metadata"
                                        IsExpanded="False">
                                        <StackPanel Margin="0,14,0,0" Spacing="12">
                                            <TextBox
                                                x:Name="MetadataNameBox"
                                                Background="{ThemeResource InputSurfaceBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                FontSize="13"
                                                PlaceholderText="File alias (optional)" />
                                            <TextBox
                                                x:Name="MetadataNotesBox"
                                                Height="72"
                                                AcceptsReturn="True"
                                                Background="{ThemeResource InputSurfaceBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                FontSize="13"
                                                PlaceholderText="Notes (optional)" />
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox
                                                    x:Name="MetadataCreatedBox"
                                                    Grid.Column="0"
                                                    Background="{ThemeResource InputSurfaceBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    FontSize="13"
                                                    PlaceholderText="Created date" />
                                                <TextBox
                                                    x:Name="MetadataModifiedBox"
                                                    Grid.Column="1"
                                                    Background="{ThemeResource InputSurfaceBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    FontSize="13"
                                                    PlaceholderText="Modified date" />
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ToggleSwitch
                                                    x:Name="MetadataRandomizeToggle"
                                                    MinWidth="0"
                                                    FontSize="13"
                                                    OffContent="Manual"
                                                    OnContent="Random"
                                                    Toggled="MetadataRandomizeToggle_Toggled" />
                                                <Button
                                                    x:Name="MetadataRandomizeButton"
                                                    Height="38"
                                                    Padding="14,0"
                                                    Background="{ThemeResource ButtonGhostBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    Click="MetadataRandomizeButton_Click"
                                                    Content="Randomize Dates"
                                                    CornerRadius="12"
                                                    Foreground="{ThemeResource TextPrimaryBrush}" />
                                            </StackPanel>
                                            <TextBlock
                                                x:Name="MetadataHelperText"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="Metadata will be preserved unless you choose manual or randomized overrides." />
                                        </StackPanel>
                                    </Expander>

                                </StackPanel>

                                </StackPanel>

                                <Border
                                    x:Name="InspectorChecksPanel"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,20,0,0"
                                    Visibility="Collapsed">
                                    <StackPanel Spacing="12">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextPrimaryBrush}"
                                            Text="Preflight" />
                                        <TextBlock
                                            x:Name="PreflightSummaryText"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Ready to run" />
                                        <ListView
                                            x:Name="PreflightListView"
                                            AutomationProperties.Name="Preflight issues"
                                            MaxHeight="150"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8" ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon
                                                            FontSize="12"
                                                            Foreground="{ThemeResource AccentBrush}"
                                                            Glyph="{Binding IconGlyph}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Style="{StaticResource CaptionTextStyle}"
                                                            Text="{Binding Message}"
                                                            TextWrapping="Wrap" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>

                                <Border
                                    x:Name="InspectorJobsPanel"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,20,0,0"
                                    Visibility="Collapsed">
                                    <StackPanel Spacing="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextPrimaryBrush}"
                                                Text="Recent jobs" />
                                            <Button
                                                x:Name="ExportMarkdownButton"
                                                AutomationProperties.Name="Export selected history as markdown"
                                                Grid.Column="1"
                                                Height="36"
                                                Padding="12,0"
                                                Margin="0,0,8,0"
                                                Background="{ThemeResource ButtonGhostBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Click="ExportMarkdownButton_Click"
                                                Content="Markdown"
                                                CornerRadius="12"
                                                Foreground="{ThemeResource TextPrimaryBrush}" />
                                            <Button
                                                x:Name="ExportCsvButton"
                                                AutomationProperties.Name="Export selected history as CSV"
                                                Grid.Column="2"
                                                Height="36"
                                                Padding="12,0"
                                                Background="{ThemeResource ButtonGhostBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Click="ExportCsvButton_Click"
                                                Content="CSV"
                                                CornerRadius="12"
                                                Foreground="{ThemeResource TextPrimaryBrush}" />
                                        </Grid>
                                        <ListView
                                            x:Name="RecentJobsListView"
                                            AutomationProperties.Name="Recent jobs"
                                            MaxHeight="180"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            SelectionMode="Single">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,10" Spacing="2">
                                                        <TextBlock
                                                            Foreground="{ThemeResource TextPrimaryBrush}"
                                                            Text="{Binding Title}" />
                                                        <TextBlock
                                                            Style="{StaticResource CaptionTextStyle}"
                                                            Text="{Binding Subtitle}" />
                                                        <TextBlock
                                                            Style="{StaticResource CaptionTextStyle}"
                                                            Text="{Binding ResultSummary}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="18,14"
                    Background="{ThemeResource StatusSurfaceBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="34"
                            Height="34"
                            Background="{ThemeResource AccentSoftBrush}"
                            CornerRadius="10">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{ThemeResource AccentBrush}"
                                Glyph="&#xE8FB;" />
                        </Border>
                        <TextBlock
                            x:Name="StatusLabel"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            Text="Ready to encrypt or decrypt files" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
